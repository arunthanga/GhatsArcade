# Normalize line endings: store LF in the repo, check out native on Windows.
* text=auto eol=lf

# Scripts that must stay LF / CRLF regardless of platform.
*.sh   text eol=lf
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Treat common binary assets as binary (no EOL/diff munging).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
*.pdf  binary
*.db   binary

# Collapse generated files in diffs / language stats.
pnpm-lock.yaml linguist-generated=true -diff
*.snap         linguist-generated=true

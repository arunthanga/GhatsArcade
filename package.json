{
  "name": "ghats-arcade",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Marketing and lead-generation website for the Ghats Arcade managed-farmland business.",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:regression": "vitest run --dir tests/regression",
    "test:report": "vitest run --coverage --reporter=html --outputFile=tests/reports/index.html",
    "test:e2e": "playwright test",
    "demo:video": "node scripts/demo-video.mjs",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@libsql/client": "^0.15.15",
    "@prisma/adapter-libsql": "^6.16.3",
    "@prisma/client": "^6.16.3",
    "@tanstack/react-query": "^5.90.2",
    "better-auth": "^1.3.9",
    "leaflet": "^1.9.4",
    "next": "^15.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.63.0",
    "react-leaflet": "^5.0.0",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^20.19.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/sanitize-html": "^2.16.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "msw": "^2.11.0",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.6",
    "prisma": "^6.16.3",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  }
}

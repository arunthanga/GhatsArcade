{
  "name": "ghats-arcade",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Marketing and lead-generation website for the Ghats Arcade managed-farmland business.",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:regression": "vitest run --dir tests/regression",
    "test:report": "vitest run --coverage --reporter=html --outputFile=tests/reports/index.html",
    "test:e2e": "playwright test",
    "demo:video": "node scripts/demo-video.mjs",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msw",
      "prisma",
      "sharp"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "latest",
    "@libsql/client": "latest",
    "@prisma/adapter-libsql": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "latest",
    "better-auth": "1.4.5",
    "leaflet": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "latest",
    "react-leaflet": "latest",
    "sanitize-html": "latest",
    "sharp": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@playwright/test": "latest",
    "@tailwindcss/postcss": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/leaflet": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/sanitize-html": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "latest",
    "jsdom": "latest",
    "msw": "latest",
    "next-sitemap": "latest",
    "postcss": "latest",
    "prisma": "^6.19.3",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}

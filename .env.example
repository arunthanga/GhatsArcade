# --- Database -------------------------------------------------------------
# Local development uses a SQLite file. Keep the SAME engine in cloud (Turso/libSQL).
DATABASE_URL="file:./dev.db"

# Cloud (Turso / libSQL) - used in production instead of the local file.
# DATABASE_URL="libsql://<your-db>.turso.io"
# DATABASE_AUTH_TOKEN="<turso-auth-token>"

# --- Auth (Better Auth) ----------------------------------------------------
# Generate a strong random secret, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET="change-me"
BETTER_AUTH_URL="http://localhost:3000"

# Credentials used by `prisma db seed` to create the single OWNER account.
OWNER_EMAIL="owner@example.com"
OWNER_PASSWORD="change-me-too"
OWNER_NAME="Ghats Arcade Owner"

# --- Public site -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# WhatsApp click-to-chat number in international format, digits only (e.g. 919876543210).
NEXT_PUBLIC_WHATSAPP_NUMBER=""

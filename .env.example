# --- Database -------------------------------------------------------------
# Local development uses a SQLite file. Keep the SAME engine in cloud (Turso/libSQL).
DATABASE_URL="file:./dev.db"

# Cloud (Turso / libSQL) - used in production instead of the local file.
# DATABASE_URL="libsql://<your-db>.turso.io"
# DATABASE_AUTH_TOKEN="<turso-auth-token>"

# --- Auth (Better Auth) ----------------------------------------------------
# Generate a strong random secret, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET="change-me"
BETTER_AUTH_URL="http://localhost:3000"

# Credentials used by `prisma db seed` to create the single OWNER account.
OWNER_EMAIL="mailarunthangavel@gmail.com"
OWNER_PASSWORD="change-me-too"
OWNER_NAME="Arun T."

# --- Public site -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# WhatsApp click-to-chat number in international format, digits only (e.g. 919876543210).
NEXT_PUBLIC_WHATSAPP_NUMBER="919901955667"

# Office / contact location for the map on /contact. Set BOTH lat & lng (decimal degrees)
# for the map to render; the address line is optional and shown beside it. Leave blank to
# hide the map. Example (Palakkad): LAT=10.7867 LNG=76.6548
NEXT_PUBLIC_OFFICE_LAT=""
NEXT_PUBLIC_OFFICE_LNG=""
NEXT_PUBLIC_OFFICE_ADDRESS=""

# Link behind the home-page "Read our Google reviews" CTA. Set to the real Google
# Business Profile / Maps reviews URL. Leave blank to fall back to a brand search.
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=""

# --- Media uploads ---------------------------------------------------------
# Uploaded photos/PDFs/videos are written here and served at UPLOAD_PUBLIC_BASE.
# Defaults keep them under Next's static public/ dir. In Docker, mount a persistent
# volume at /app/public/uploads so uploads survive redeploys.
UPLOAD_DIR="public/uploads"
UPLOAD_PUBLIC_BASE="/uploads"
MAX_IMAGE_UPLOAD_MB="15"
MAX_PDF_UPLOAD_MB="25"
MAX_VIDEO_UPLOAD_MB="200"

# --- Transactional email (Resend) -----------------------------------------
# Optional. When RESEND_API_KEY is blank, inquiry confirmation emails are skipped
# (the lead is still captured). Get a key + verified sender at https://resend.com.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Ghats Arcade <onboarding@resend.dev>"
